-- Better private server detection
local isPrivate = game.PrivateServerOwnerId ~= 0

if isPrivate then
    if game.Players.LocalPlayer then
        game.StarterGui:SetCore("SendNotification", {
            Title = "Public Server Required",
            Text = "Please join a public server to use this script.",
            Duration = 5
        })
    else
        warn("Please join a public server to use this script.")
    end

    task.wait(5)
    return
end

